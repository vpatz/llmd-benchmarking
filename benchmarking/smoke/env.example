# Copy to smoke.env and customize:  source smoke.env  (or export manually)
# Usage:  cd benchmarking/smoke && source ./smoke.env 2>/dev/null || true; ./run-all.sh

# --- Required for inference checks (S05–S07) ---
# External Route (laptop / bastion) — example from local_run.sh:
# export SMOKE_TARGET="https://inference-gateway.apps.sovereign-ai-stack-cl02.ocp.speedcloud.co.in/vinod/qwen2-7b-instruct-nvidia"
# In-cluster Service (must run from a pod in cluster or oc run — see README):
# export SMOKE_TARGET="http://qwen2-7b-instruct-nvidia-epp-service.vinod.svc.cluster.local:9002"
# Benchmark Job + PVC live in namespace varun-benchmark; inference Service may stay in vinod.

export SMOKE_TARGET="${SMOKE_TARGET:-}"

# Model id must match server /v1/models
export SMOKE_MODEL="${SMOKE_MODEL:-Qwen/Qwen2.5-7B-Instruct}"

# If gateway requires Bearer auth (use real token; not a placeholder):
export SMOKE_API_KEY="${SMOKE_API_KEY:-}"

# Private / untrusted TLS (OpenShift default ingress CA): 1 = curl -k behavior
export SMOKE_INSECURE="${SMOKE_INSECURE:-1}"

# GuideLLM HTML report template (same family as GUIDELLM__REPORT_GENERATION__SOURCE)
export SMOKE_GUIDELLM_UI_URL="${SMOKE_GUIDELLM_UI_URL:-https://raw.githubusercontent.com/vllm-project/guidellm/refs/heads/gh-pages/ui/v0.5.4/index.html}"

# Hugging Face (dataset download in Job)
export SMOKE_HF_URL="${SMOKE_HF_URL:-https://huggingface.co}"

# Skip checks (space-separated): S01 S02 …
export SMOKE_SKIP="${SMOKE_SKIP:-}"
